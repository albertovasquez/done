.env
.DS_Store
*.pdf
harness/runs/
__pycache__/
# compress-aware shadow files — generated from source via `dn compress`,
# rebuilt on demand, never the source of truth (see docs/compress-aware.md).
*.compressed.md
*.pyc
*.egg-info/
build/
dist/
.pytest_cache/
.superpowers/
.worktrees/
vendor/
.venv/
# stray submit-sentinel artifact (echo COMPLETE_TASK_AND_SUBMIT_FINAL_OUTPUT
# accidentally redirected to a file instead of stdout)
.task_complete

# pytest-textual-snapshot writes this HTML failure report into whatever cwd
# pytest was invoked from on any snapshot mismatch/failure — not test output we
# want tracked (the baseline .svg files under tests/__snapshots__/ ARE tracked).
snapshot_report.html

# The ROOT AGENTS.md is a SHARED, committed operating standard for this repo. The
# user's global gitignore (~/.config/git/ignore) ignores AGENTS.md everywhere;
# this negation re-includes ONLY the root one so the team gets it. (CLAUDE.md
# stays local; upstream/AGENTS.md stays ignored — upstream is vendored, untracked.)
!/AGENTS.md
