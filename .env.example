# Model proxy (CLIProxyAPI).
# PROXY_* is canonical; VIBEPROXY_* are still honored as legacy (PROXY_* wins if both set).
PROXY_BASE_URL=http://localhost:8317/v1
PROXY_MODEL=gpt-4-turbo
# PROXY_API_KEY is normally NOT needed: `dn proxy install/upgrade` provisions a
# client key and the harness reads it automatically. Set this only to override
# (e.g. a non-CLIProxyAPI proxy with its own auth).
# PROXY_API_KEY=

# Legacy VibeProxy environment variables (still supported but deprecated).
# If you have these set, rename them to PROXY_* above. Both names work, but PROXY_* takes precedence.
# VIBEPROXY_BASE_URL=http://localhost:8317/v1
# VIBEPROXY_MODEL=gpt-4-turbo
